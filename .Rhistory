knitr::opts_chunk$set(
echo = FALSE, warning = FALSE, message = FALSE, error = FALSE,
fig.align = "center", fig.pos = "H", fig.path = "figures_v4/", dev = c("png", "pdf"),
out.width = "90%", dpi = 300
)
suppressPackageStartupMessages({
library(tidyverse)
library(psych)
library(effectsize)
library(car)
library(knitr)
library(gridExtra)
library(lme4)
library(lmerTest)
library(pROC)
library(ggplot2)
library(pheatmap)
library(viridis)
library(broom)
library(broom.mixed)
library(emmeans)
})
# Load Data
DATA <- file.path(normalizePath(".."), "extracted_data")
retrieval <- read_csv(file.path(DATA, "retrieval_trials.csv"), show_col_types = FALSE)
metrics   <- read_csv(file.path(DATA, "participant_metrics.csv"), show_col_types = FALSE)
lure_bins <- read_csv(file.path(DATA, "lure_bin_metrics.csv"), show_col_types = FALSE)
# Formatting Factors
metrics$boundary_position <- factor(metrics$boundary_position, levels = c("pre","mid","post"))
metrics$group <- factor(metrics$group, levels = c("item_only","task_only","Both_item_task"))
retrieval$boundary_position <- factor(retrieval$boundary_position, levels = c("pre","mid","post","none"))
retrieval$group <- factor(retrieval$group, levels = c("item_only","task_only","Both_item_task"))
retrieval$stimulus_type <- factor(retrieval$stimulus_type)
retrieval$participant <- factor(retrieval$participant)
# Load and Process Encoding Data for Speed Bump
encoding <- read_csv(file.path(DATA, "encoding_trials.csv"), show_col_types = FALSE) %>%
mutate(position = (trial_n %% 7) + 1) %>%
mutate(boundary_pos = case_when(
position == 1 ~ "post",
position == 4 ~ "mid",
position == 7 ~ "pre",
TRUE ~ "other"
)) %>%
filter(boundary_pos != "other") %>%
mutate(boundary_pos = factor(boundary_pos, levels = c("pre", "mid", "post")))
# Compute Trial-Level Binary Accuracy
retrieval <- retrieval %>%
mutate(
accuracy = case_when(
stimulus_type == "Target" & response == "o" ~ 1,
stimulus_type == "Foil" & response == "n" ~ 1,
stimulus_type == "Lure" & response == "s" ~ 1,
TRUE ~ 0
)
)
test_targets <- retrieval %>% filter(stimulus_type == "Target")
# Fit standard GLMM for Target Accuracy
glmm_mod <- glmer(accuracy ~ boundary_position * group + (1|participant),
data = test_targets, family = binomial)
lure_bins$group <- factor(lure_bins$group, levels = c("item_only","task_only","Both_item_task"))
lure_bins$lure_bin <- as.numeric(lure_bins$lure_bin)
# Setup Theme
theme_report <- theme_minimal(base_size = 12) +
theme(plot.title = element_text(face = "bold", hjust = 0.5, size = 14),
plot.subtitle = element_text(hjust = 0.5, colour = "grey40", size = 12),
legend.position = "bottom",
strip.text = element_text(face = "bold", size = 12),
plot.margin = margin(10, 10, 10, 10))
clr <- c("Both_item_task"="#1b9e77","item_only"="#d95f02","task_only"="#7570b3")
lbl <- c("Both","Item Only","Task Only")
p1 <- ggplot(metrics, aes(x = group, y = REC, fill = group)) +
geom_violin(alpha = 0.5, width=0.8, color="black", linetype="solid") +
geom_boxplot(width = 0.15, fill="white", outlier.shape = 21, color="black") +
scale_fill_manual(values = clr, labels = lbl) +
scale_x_discrete(labels = lbl) +
theme_report + theme(legend.position = "none") +
labs(x = "Categorical Group", y = "Holistic Recognition Recall (REC)", title="Base Memory Capability Mapping")
lure_bin_summary <- lure_bins %>%
group_by(group, lure_bin) %>%
summarise(mean_p = mean(p_similar, na.rm=TRUE), se_p = sd(p_similar, na.rm=TRUE)/sqrt(n()), .groups="drop")
p2 <- ggplot(lure_bin_summary, aes(x = factor(lure_bin), y = mean_p, colour = group, group = group)) +
geom_line(linewidth = 1.2) + geom_point(size = 3) +
geom_errorbar(aes(ymin = mean_p - se_p, ymax = mean_p + se_p), width = 0.15) +
scale_colour_manual(values = clr, labels = lbl) +
theme_report + theme(legend.position = "none") +
labs(x = "Sequential Lure Classification Bin", y = "P('Similar'|Lure)", title="Lure Differentiation Scale")
grid.arrange(p1, p2, ncol = 2)
# Relevel boundary_position to use 'mid' as reference for positional contrasts
metrics_h1 <- metrics %>%
mutate(boundary_position = relevel(boundary_position, ref = "mid"))
# REC model
mod_h1_rec <- lmer(REC ~ boundary_position + (1|participant), data = metrics_h1)
h1_rec_tidy <- tidy(mod_h1_rec, effects = "fixed") %>%
mutate(Metric = "REC")
# LDI model
mod_h1_ldi <- lmer(LDI ~ boundary_position + (1|participant), data = metrics_h1)
h1_ldi_tidy <- tidy(mod_h1_ldi, effects = "fixed") %>%
mutate(Metric = "LDI")
h1_combined <- bind_rows(h1_rec_tidy, h1_ldi_tidy) %>%
mutate(across(where(is.numeric), ~round(., 3))) %>%
mutate(p_val = format.pval(p.value, eps = 0.001))
knitr::kable(h1_combined %>% select(Metric, term, estimate, std.error, statistic, p_val),
caption = "LMM Results for Positional Effects (H1).",
booktabs = TRUE)
h1_rec_means <- metrics %>%
group_by(boundary_position) %>%
summarise(mean_val = mean(REC, na.rm = TRUE),
se = sd(REC, na.rm = TRUE)/sqrt(n()), .groups = "drop") %>%
mutate(Metric = "REC")
h1_ldi_means <- metrics %>%
group_by(boundary_position) %>%
summarise(mean_val = mean(LDI, na.rm = TRUE),
se = sd(LDI, na.rm = TRUE)/sqrt(n()), .groups = "drop") %>%
mutate(Metric = "LDI")
h1_plot_data <- bind_rows(h1_rec_means, h1_ldi_means)
ggplot(h1_plot_data, aes(x = boundary_position, y = mean_val, group = Metric, color = Metric)) +
geom_line(linewidth = 1.2) +
geom_point(size = 4) +
geom_errorbar(aes(ymin = mean_val - se, ymax = mean_val + se), width = 0.1) +
scale_color_manual(values = c("REC" = "#2c3e50", "LDI" = "#e74c3c")) +
labs(x = "Boundary Position", y = "Mean Score",
title = "Replication Gradient: Mean REC and LDI across Positions") +
theme_report
# Mixed-effects ANOVA for Encoding RT (Post vs Mid)
# This captures the 'Speed Bump' cost under high load
ebump_data <- encoding %>% filter(boundary_pos %in% c("post", "mid"))
mod_h4_rt <- lmer(combined_rt ~ boundary_pos * group + (1|participant), data = ebump_data)
h4_rt_anova <- anova(mod_h4_rt, type = 3)
h4_rt_tbl <- as.data.frame(h4_rt_anova) %>%
rownames_to_column("Term") %>%
mutate(across(where(is.numeric), ~round(., 3))) %>%
mutate(`p-value` = format.pval(`Pr(>F)`, eps = 0.001))
knitr::kable(h4_rt_tbl[, c("Term", "F value", "NumDF", "DenDF", "p-value")],
caption = "Type III ANOVA: Encoding RT Interaction (Position x Group).",
booktabs = TRUE)
# Binomial logistic regression for Lure Discrimination
# We analyze the probability of identifying a lure as 'Similar' (Correct)
lure_data <- retrieval %>% filter(stimulus_type == "Lure")
mod_h5 <- glmer(response == "s" ~ lure_bin * group + (1|participant),
data = lure_data, family = binomial)
h5_summary <- tidy(mod_h5, effects = "fixed") %>%
mutate(term = case_when(
term == "(Intercept)" ~ "(Intercept) [Item Only]",
term == "lure_bin" ~ "lure_bin [Item Only]",
term == "grouptask_only" ~ "group (Task Only)",
term == "groupBoth_item_task" ~ "group (Both Item & Task)",
term == "lure_bin:grouptask_only" ~ "lure_bin:task_only",
term == "lure_bin:groupBoth_item_task" ~ "lure_bin:Both",
TRUE ~ term
)) %>%
mutate(across(where(is.numeric), ~round(., 3))) %>%
mutate(p_val = format.pval(p.value, eps = 0.001))
knitr::kable(h5_summary %>% select(term, estimate, std.error, statistic, p_val),
caption = "GLMM results showing fixed effects of lure similarity (Lure Bin) on discrimination accuracy.",
booktabs = TRUE)
lure_bins %>%
ggplot(aes(x = factor(lure_bin), y = p_similar, fill = group)) +
geom_boxplot(alpha=0.7, outlier.shape = NA) +
geom_jitter(aes(color=group), width=0.2, alpha=0.3) +
scale_fill_manual(values = clr, labels = lbl) +
scale_color_manual(values = clr, labels = lbl) +
labs(x = "Lure Similarity Bin (1 = Most Similar)", y = "P('Similar'|Lure)") +
theme_report
# Summary of the GLMM for target accuracy
h6_summary <- tidy(glmm_mod, effects = "fixed", conf.int = TRUE) %>%
mutate(term = case_when(
term == "(Intercept)" ~ "Intercept (Item Only, Pre-boundary baseline)",
term == "boundary_positionmid" ~ "Mid vs Pre boundary position",
term == "boundary_positionpost" ~ "Post vs Pre boundary position",
term == "grouptask_only" ~ "Task Only vs Item Only group",
term == "groupBoth_item_task" ~ "Both (Item + Task) vs Item Only group",
term == "boundary_positionmid:grouptask_only" ~ "Mid × Task Only interaction",
term == "boundary_positionpost:grouptask_only" ~ "Post × Task Only interaction",
term == "boundary_positionmid:groupBoth_item_task" ~ "Mid × Both condition interaction",
term == "boundary_positionpost:groupBoth_item_task" ~ "Post × Both condition interaction",
TRUE ~ term
)) %>%
mutate(across(where(is.numeric), ~round(., 3))) %>%
mutate(p_val = format.pval(p.value, eps = 0.001))
knitr::kable(h6_summary %>% select(term, estimate, std.error, statistic, p_val, conf.low, conf.high),
caption = "GLMM results predicting the probability of correct responses at the trial level. The reference condition is the Item Only group at the Pre-boundary position.",
booktabs = TRUE)
# Mixed-effects model testing the main effect of boundary position on REC
# Satterthwaite's method for DF
boundary_mod_h7 <- lmer(REC ~ boundary_position + (1|participant), data = metrics)
h7_anova <- anova(boundary_mod_h7, type = 3)
h7_tbl <- as.data.frame(h7_anova) %>%
rownames_to_column("Term") %>%
mutate(across(where(is.numeric), ~round(., 3))) %>%
mutate(p_val = format.pval(`Pr(>F)`, eps = 0.001))
knitr::kable(h7_tbl %>% select(Term, F_value = `F value`, NumDF, DenDF, p_val),
caption = "Type III ANOVA: Main Effect of Boundary Position on Recognition (H7).",
booktabs = TRUE)
metrics %>%
group_by(boundary_position) %>%
summarise(mean_rec = mean(REC, na.rm=TRUE), se = sd(REC, na.rm=TRUE)/sqrt(n()), .groups = "drop") %>%
ggplot(aes(x = boundary_position, y = mean_rec, group = 1)) +
geom_line(color = "grey", linewidth = 1) +
geom_point(size = 4, color = "#2c3e50") +
geom_errorbar(aes(ymin = mean_rec - se, ymax = mean_rec + se), width = 0.1) +
scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +
labs(x = "Event Boundary Position", y = "Mean Recognition Accuracy (REC)") +
theme_report
# Use encoding data with pre/mid/post boundary positions
# Relevel so that 'post' is the reference (hypothesised peak RT)
encoding_lmm <- encoding %>%
mutate(boundary_pos = relevel(boundary_pos, ref = "post"),
participant = factor(participant))
# Fit LMM with post as reference
mod_enc_rt <- lmer(combined_rt ~ boundary_pos + (1|participant), data = encoding_lmm)
enc_summary <- tidy(mod_enc_rt, effects = "fixed") %>%
mutate(across(where(is.numeric), ~round(., 3))) %>%
mutate(p_val = format.pval(p.value, eps = 0.001))
knitr::kable(enc_summary %>% select(term, estimate, std.error, statistic, p_val),
caption = "LMM Results for Encoding Position RT (H4).",
col.names = c("Position", "Estimate (s)", "Std. Error", "t-value", "p-value"),
booktabs = TRUE)
encoding %>%
group_by(boundary_pos) %>%
summarise(mean_rt = mean(combined_rt, na.rm = TRUE),
se = sd(combined_rt, na.rm = TRUE)/sqrt(n()), .groups = "drop") %>%
ggplot(aes(x = boundary_pos, y = mean_rt, group = 1)) +
geom_line(color = "grey40", linewidth = 1) +
geom_point(size = 4, color = "#2c3e50") +
geom_errorbar(aes(ymin = mean_rt - se, ymax = mean_rt + se), width = 0.15) +
labs(x = "Boundary Position", y = "Mean Encoding RT (s)",
title = "Encoding RT by Boundary Position") +
theme_report
# ANOVA for Task Group main effect
group_mod_new <- lmer(REC ~ group + (1|participant), data = metrics)
group_anova_new <- anova(group_mod_new, type = 3)
group_tbl_new <- as.data.frame(group_anova_new) %>%
rownames_to_column("Term") %>%
mutate(across(where(is.numeric), ~round(., 3)))
knitr::kable(group_tbl_new,
caption = "Type III ANOVA: The Task-Set Interference Effect (Group Main Effect).",
booktabs = TRUE)
target_heat <- test_targets %>% group_by(group, boundary_position) %>%
summarise(hr = mean(accuracy), .groups="drop")
heat_obj <- reshape2::dcast(target_heat, group ~ boundary_position, value.var = "hr")
rownames(heat_obj) <- lbl
heat_obj$group <- NULL
pheatmap(as.matrix(heat_obj),
color = viridis(100, option = "mako"),
display_numbers = TRUE,
number_color = "white",
fontsize_number = 14,
cluster_rows = FALSE,
cluster_cols = FALSE)
# Fit GLMM for target trials (already computed as glmm_mod)
prob <- predict(glmm_mod, type = "response")
roc_obj <- roc(test_targets$accuracy, prob)
# Plot ROC
plot(roc_obj, col = "#1b9e77", lwd = 2, main = "GLMM Target ROC Curve")
abline(a=0, b=1, lty=2, col = "grey")
auc_val <- auc(roc_obj)
legend("bottomright", legend = paste0("AUC = ", round(auc_val, 3)), bty = "n")
# Extract random effects
re_df <- as.data.frame(ranef(glmm_mod)$participant)
re_df$participant <- rownames(re_df)
colnames(re_df) <- c("Intercept", "participant")
# Plot forest plot
ggplot(re_df, aes(x = Intercept, y = reorder(participant, Intercept))) +
geom_point(color = "#7570b3") +
geom_errorbarh(aes(xmin = Intercept - 1.96*attr(ranef(glmm_mod)$participant, "postVar")[,,1]^0.5,
xmax = Intercept + 1.96*attr(ranef(glmm_mod)$participant, "postVar")[,,1]^0.5),
height = 0.2, color = "#7570b3") +
geom_vline(xintercept = 0, linetype = "dashed", color = "grey") +
theme_minimal() +
labs(x = "Random Intercept (log-odds)", y = "Participant")
# Prepare data frame for correlations
# Compute participant-level aggregates for rt and accuracy
participant_rt_acc <- test_targets %>% group_by(participant) %>% summarise(rt = mean(rt, na.rm=TRUE), accuracy = mean(accuracy, na.rm=TRUE))
# Merge with existing metrics and select core numeric columns for correlation
corr_df <- metrics %>% distinct(participant, overall_REC, overall_LDI) %>% inner_join(participant_rt_acc, by = "participant") %>% select(overall_REC, overall_LDI, rt, accuracy) %>% drop_na()
colnames(corr_df) <- c("REC", "LDI", "RT", "Accuracy")
cor_mat <- round(cor(corr_df), 2)
pheatmap(cor_mat,
display_numbers = TRUE,
color = viridis(100, option = "plasma"),
fontsize_number = 12,
border_color = NA,
main = "Core Metric Correlations")
lure_bins %>%
mutate(lure_bin = factor(lure_bin, levels = 1:5)) %>%
ggplot(aes(x = lure_bin, y = p_similar, colour = group, group = group)) +
geom_point(size = 3) +
geom_line(aes(group = group), linewidth = 1.2) +
facet_wrap(~group) +
scale_colour_manual(values = clr, labels = lbl) +
labs(x = "Lure Bin (1 = Most Similar)", y = "P('Similar'|Lure)") +
theme_minimal(base_size = 12) +
theme(legend.position = "none")
